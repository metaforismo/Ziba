{
  "extends": "@synapsium/tsconfig/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "noEmit": true
  },
  "include": ["electron/**/*", "shared/**/*", "electron.vite.config.ts"]
}
